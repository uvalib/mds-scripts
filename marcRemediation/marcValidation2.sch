            <value-of select="concat($record001, ' :: ')"/>Type of visual material (char position 34, 1) must match '[abcdefgiklmnopqrstvwz\|]'.</assert>
         <assert role="error" test="matches(substring(., 35, 1), '[\p{Zs}aclnuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Technique (char position 35, 1) must match '[\p{Zs}aclnuz\|]'.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 MIXED MATERIALS</title>
      <rule context="*:controlfield[@tag = '008'][matches(substring(../*:leader, 7, 1), 'p')]">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
         <!-- Requirements -->
         <assert role="error" test="matches(substring(., 19, 5), '[\p{Zs}\|]{5}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 19, 5) must match '[\p{Zs}\|]{5}'.</assert>
         <assert role="error"
                 test="matches(substring(., 24, 1), '[\p{Zs}abcdfghijopqrstz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of item (char position 24, 1) must match '[\p{Zs}abcdfghijopqrstz\|]'.</assert>
         <assert role="error" test="matches(substring(., 25, 11), '[\p{Zs}\|]{11}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 25, 11) must match '[\p{Zs}\|]{11}'.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>009 PHYSICAL DESCRIPTION FIXED-FIELD FOR ARCHIVAL COLLECTION (VM)</title>
      <rule context="*:controlfield[@tag = '009']">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
      </rule>
   </pattern>
   <!-- DATA FIELDS -->
   <!-- 010 LIBRARY OF CONGRESS CONTROL NUMBER -->
   <pattern>
      <title>010 LIBRARY OF CONGRESS CONTROL NUMBER</title>
      <rule context="*:datafield[@tag = '010'] | *:datafield[@tag =           '880'][matches(*:subfield[@code = '6'], '^010')]">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
         <!-- Field repeatability -->
         <assert test="not(count(../*[@tag = '010']) &gt; 1)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> is not repeatable.</assert>
         <!-- Indicators -->
         <assert test="matches(@ind1, '^[ ]$')" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> ind1 must match "[\s]".</assert>
         <assert test="matches(@ind2, '^[ ]$')" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> ind2 must match "[\s]".</assert>
         <!-- Valid subfields -->
         <report test="*:subfield[not(matches(@code, '^[abz8]$'))]" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> invalid subfield @code(s):
                <value-of select="string-join(*:subfield[not(matches(@code, '^[abz8]$'))]/@code, ', ')"/>
         </report>
         <!-- Non-repeatable subfields -->
         <assert test="not(count(*:subfield[@code = 'a']) &gt; 1)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂa is not
                  repeatable.</assert>
      </rule>
   </pattern>
   <!-- 013 PATENT CONTROL INFORMATION -->
   <pattern>
      <title>013 PATENT CONTROL INFORMATION</title>
      <rule context="*:datafield[@tag = '013'] | *:datafield[@tag =           '880'][matches(*:subfield[@code = '6'], '^013')]">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
         <!-- Indicators -->
         <assert test="matches(@ind1, '^[ ]$')" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> ind1 must match "[\s]".</assert>
         <assert test="matches(@ind2, '^[ ]$')" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> ind2 must match "[\s]".</assert>
         <!-- Valid subfields -->
