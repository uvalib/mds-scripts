            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂx is not
                  repeatable.</assert>
         <assert test="not(count(*:subfield[@code = 'z']) &gt; 1)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂz is not
                  repeatable.</assert>
         <assert test="not(count(*:subfield[@code = '0']) &gt; 1)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂ0 is not
                  repeatable.</assert>
         <assert test="not(count(*:subfield[@code = '1']) &gt; 1)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂ1 is not
                  repeatable.</assert>
         <assert test="not(count(*:subfield[@code = '2']) &gt; 1)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂ2 is not
                  repeatable.</assert>
         <!-- Required subfields -->
         <assert test="*:subfield[@code = 'a']" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂa is
                required.</assert>
         <assert test="*:subfield[@code = 'w']" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Datafield ', @tag)"/> subfield ǂw is
                required.</assert>
      </rule>
   </pattern>
</schema>
