         <assert role="error"
                 test="matches(substring(., 19, 1), '[\p{Zs}abcdefghijkmqstuwz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Frequency (char position 19, 1) must match '[\p{Zs}abcdefghijkmqstuwz\|]'.</assert>
         <assert role="error" test="matches(substring(., 20, 1), '[nrux\|]')">
            <value-of select="concat($record001, ' :: ')"/>Regularity (char position 20, 1) must match '[nrux\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 22, 1), '[\p{Zs}dghjlmnprstw\|]')">
            <value-of select="concat($record001, ' :: ')"/>Type of continuing resource (char position 22, 1) must match '[\p{Zs}dghjlmnprstw\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 23, 1), '[\p{Zs}abcdefghioqsxz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of original item (char position 23, 1) must match '[\p{Zs}abcdefghioqsxz\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 24, 1), '[\p{Zs}abcdfghioqrsz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of item (char position 24, 1) must match '[\p{Zs}abcdfghioqrsz\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 25, 1), '[\p{Zs}abcdefghiklmnopqrstuvwyz56\|]')">
            <value-of select="concat($record001, ' :: ')"/>Nature of entire work (char position 25, 1) must match '[\p{Zs}abcdefghiklmnopqrstuvwyz56\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 26, 3), '[\p{Zs}abcdefghiklmnopqrstuvwyz56\|]{3}')">
            <value-of select="concat($record001, ' :: ')"/>Nature of contents (char position 26, 3) must match '[\p{Zs}abcdefghiklmnopqrstuvwyz56\|]{3}'.</assert>
         <assert role="error"
                 test="matches(substring(., 29, 1), '[\p{Zs}acfilmnosuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Government publication (char position 29, 1) must match '[\p{Zs}acfilmnosuz\|]'.</assert>
         <assert role="error" test="matches(substring(., 30, 1), '[01\|]')">
            <value-of select="concat($record001, ' :: ')"/>Conference publication (char position 30, 1) must match '[01\|]'.</assert>
         <assert role="error" test="matches(substring(., 31, 3), '[\p{Zs}\|]{3}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 31, 3) must match '[\p{Zs}\|]{3}'.</assert>
         <assert role="error"
                 test="matches(substring(., 34, 1), '[\p{Zs}abcdefghijkluz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Original alphabet or script of title (char position 34, 1) must match '[\p{Zs}abcdefghijkluz\|]'.</assert>
         <assert role="error" test="matches(substring(., 35, 1), '[012\|]')">
            <value-of select="concat($record001, ' :: ')"/>Entry convention (char position 35, 1) must match '[012\|]'.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 VISUAL MATERIALS</title>
      <rule context="*:controlfield[@tag = '008'][matches(substring(../*:leader, 7, 1), '[gkor]')]">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
