         <assert role="error"
                 test="matches(substring(., 23, 2), '(\p{Zs}\p{Zs}|aa|ab|ac|ad|ae|af|ag|am|an|ap|au|az|ba|bb|bc|bd|be|bf|bg|bh|bi|bj|bk|bl|bo|br|bs|bu|bz|ca|cb|cc|ce|cp|cu|cz|da|db|dc|dd|de|df|dg|dh|dl|zz|\|\|)')">
            <value-of select="concat($record001, ' :: ')"/>Projection (char position 23, 2) must match '(\p{Zs}\p{Zs}|aa|ab|ac|ad|ae|af|ag|am|an|ap|au|az|ba|bb|bc|bd|be|bf|bg|bh|bi|bj|bk|bl|bo|br|bs|bu|bz|ca|cb|cc|ce|cp|cu|cz|da|db|dc|dd|de|df|dg|dh|dl|zz|\|\|)'.</assert>
         <assert role="error" test="matches(substring(., 25, 1), '[\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 25, 1) must match '[\p{Zs}\|]'.</assert>
         <assert role="error" test="matches(substring(., 26, 1), '[abcdefguz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Type of cartographic material (char position 26, 1) must match '[abcdefguz\|]'.</assert>
         <assert role="error" test="matches(substring(., 27, 2), '[\p{Zs}\|]{2}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 27, 2) must match '[\p{Zs}\|]{2}'.</assert>
         <assert role="error"
                 test="matches(substring(., 29, 1), '[\p{Zs}acfilmosuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Government publication (char position 29, 1) must match '[\p{Zs}acfilmosuz\|]'.</assert>
         <assert role="error" test="matches(substring(., 30, 1), '[\p{Zs}abcdfoqrs\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of item (char position 30, 1) must match '[\p{Zs}abcdfoqrs\|]'.</assert>
         <assert role="error" test="matches(substring(., 31, 1), '[\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 31, 1) must match '[\p{Zs}\|]'.</assert>
         <assert role="error" test="matches(substring(., 32, 1), '[01\|]')">
            <value-of select="concat($record001, ' :: ')"/>Index (char position 32, 1) must match '[01\|]'.</assert>
         <assert role="error" test="matches(substring(., 33, 1), '[\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 33, 1) must match '[\p{Zs}\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 34, 2), '[\p{Zs}abcdefghjklmnopqrz\|]{2}')">
            <value-of select="concat($record001, ' :: ')"/>Special format characteristics (char position 34, 2) must match '[\p{Zs}abcdefghjklmnopqrz\|]{2}'.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 MUSIC</title>
      <rule context="*:controlfield[@tag = '008'][matches(substring(../*:leader, 7, 1), '[cdij]')]">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
         <!-- Requirements -->
         <assert role="error"
                 test="matches(substring(., 19, 2), '(an|bd|bg|bl|bt|ca|cb|cc|cg|ch|cl|cn|co|cp|cr|cs|ct|cy|cz|df|dv|fg|fl|fm|ft|gm|hy|jz|mc|md|mi|mo|mp|mr|ms|mu|mz|nc|nn|op|or|ov|pg|pm|po|pp|pr|ps|pt|pv|rc|rd|rg|ri|rp|rq|sd|sg|sn|sp|st|su|sy|tc|tl|ts|uu|vi|vr|wz|za|zz|\|\|)')">
            <value-of select="concat($record001, ' :: ')"/>Form of composition (char position 19, 2) must match '(an|bd|bg|bl|bt|ca|cb|cc|cg|ch|cl|cn|co|cp|cr|cs|ct|cy|cz|df|dv|fg|fl|fm|ft|gm|hy|jz|mc|md|mi|mo|mp|mr|ms|mu|mz|nc|nn|op|or|ov|pg|pm|po|pp|pr|ps|pt|pv|rc|rd|rg|ri|rp|rq|sd|sg|sn|sp|st|su|sy|tc|tl|ts|uu|vi|vr|wz|za|zz|\|\|)'.</assert>
         <assert role="error"
                 test="matches(substring(., 21, 1), '[abcdeghijklmnpuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Format of music (char position 21, 1) must match '[abcdeghijklmnpuz\|]'.</assert>
         <assert role="error" test="matches(substring(., 22, 1), '[\p{Zs}defnu\|]')">
            <value-of select="concat($record001, ' :: ')"/>Music parts (char position 22, 1) must match '[\p{Zs}defnu\|]'.</assert>
         <assert role="error" test="matches(substring(., 23, 1), '[\p{Zs}abcdefgj\|]')">
            <value-of select="concat($record001, ' :: ')"/>Target audience (char position 23, 1) must match '[\p{Zs}abcdefgj\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 24, 1), '[\p{Zs}abcdfghioqrsxz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of item (char position 24, 1) must match '[\p{Zs}abcdfghioqrsxz\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 25, 6), '[\p{Zs}abcdefghijknrsz\|]{6}')">
            <value-of select="concat($record001, ' :: ')"/>Accompanying matter (char position 25, 6) must match '[\p{Zs}abcdefghijknrsz\|]{6}'.</assert>
         <assert role="error"
                 test="matches(substring(., 31, 2), '[\p{Zs}abcdefghijklmnoprstz\|]{2}')">
            <value-of select="concat($record001, ' :: ')"/>Literary text for sound recordings (char position 31, 2) must match '[\p{Zs}abcdefghijklmnoprstz\|]{2}'.</assert>
         <assert role="error" test="matches(substring(., 33, 1), '[\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 33, 1) must match '[\p{Zs}\|]'.</assert>
         <assert role="error" test="matches(substring(., 34, 1), '[\p{Zs}abcnu\|]')">
            <value-of select="concat($record001, ' :: ')"/>Transposition and arrangement (char position 34, 1) must match '[\p{Zs}abcnu\|]'.</assert>
         <assert role="error" test="matches(substring(., 35, 1), '[\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 35, 1) must match '[\p{Zs}\|]'.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 CONTINUING RESOURCES</title>
