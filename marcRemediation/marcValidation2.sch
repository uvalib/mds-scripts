      <title>008 country code</title>
      <rule context="*:controlfield[@tag = '008']">
         <let name="record001" value="../*:controlfield[@tag = '001']"/>
         <assert test="matches(substring(., 16, 3), $marcCountryCodes)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Controlfield ', @tag)"/> Place of publication (position 15-17)
          must match a valid MARC country code.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 language code</title>
      <rule context="*:controlfield[@tag = '008']">
         <let name="record001" value="../*:controlfield[@tag = '001']"/>
         <assert test="matches(substring(., 36, 3), $marcLangCodes)" role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Controlfield ', @tag)"/> Language (position 35-37) must match
          a valid MARC language code.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 Date 1</title>
      <rule context="*:controlfield[@tag = '008']">
         <let name="record001" value="../*:controlfield[@tag = '001']"/>
         <assert test="matches(substring(., 8, 4), '[\du]{4}|\s{4}|\|{4}|u{4}')"
                 role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Controlfield ', @tag)"/> Date 1 (position 8-11) must
          match 4 digits or 'u' chars, 4 spaces, 4 pipes, or 4 'u' chars.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 Date 2</title>
      <rule context="*:controlfield[@tag = '008']">
         <let name="record001" value="../*:controlfield[@tag = '001']"/>
         <assert test="matches(substring(., 12, 4), '[\du]{4}|\s{4}|\|{4}|u{4}')"
                 role="error">
            <value-of select="concat($record001, ' :: ')"/>
            <value-of select="concat('Controlfield ', @tag)"/> Date 2 (position 12-15) must
          match 4 digits or 'u' chars, 4 spaces, 4 pipes, or 4 'u' chars.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 BOOKS</title>
      <rule context="*:controlfield[@tag = '008'][matches(substring(../*:leader, 7, 1), '[at]') and matches(substring(../*:leader, 8, 1), '[acdm]')]">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
         <!-- Requirements -->
         <assert role="error"
                 test="matches(substring(., 19, 4), '[\p{Zs}abcdefghijklmop\|]{4}')">
            <value-of select="concat($record001, ' :: ')"/>Illustrations (char position 19, 4) must match '[\p{Zs}abcdefghijklmop\|]{4}'.</assert>
         <assert role="error" test="matches(substring(., 23, 1), '[\p{Zs}abcdefgj\|]')">
            <value-of select="concat($record001, ' :: ')"/>Target audience (char position 23, 1) must match '[\p{Zs}abcdefgj\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 24, 1), '[\p{Zs}abcdfghioqrsz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of item (char position 24, 1) must match '[\p{Zs}abcdfghioqrsz\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 25, 4), '[\p{Zs}abcdefghijklmnopqrstuvwxyz256\|]{4}')">
            <value-of select="concat($record001, ' :: ')"/>Nature of contents (char position 25, 4) must match '[\p{Zs}abcdefghijklmnopqrstuvwxyz256\|]{4}'.</assert>
         <assert role="error"
                 test="matches(substring(., 29, 1), '[\p{Zs}acfilmnosuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Government publication (char position 29, 1) must match '[\p{Zs}acfilmnosuz\|]'.</assert>
         <assert role="error" test="matches(substring(., 30, 1), '[01\|]')">
            <value-of select="concat($record001, ' :: ')"/>Conference publication (char position 30, 1) must match '[01\|]'.</assert>
         <assert role="error" test="matches(substring(., 31, 1), '[01\|]')">
            <value-of select="concat($record001, ' :: ')"/>Festschrift (char position 31, 1) must match '[01\|]'.</assert>
         <assert role="error" test="matches(substring(., 32, 1), '[01\|]')">
            <value-of select="concat($record001, ' :: ')"/>Index (char position 32, 1) must match '[01\|]'.</assert>
         <assert role="error" test="matches(substring(., 33, 1), '[\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 33, 1) must match '[\p{Zs}\|]'.</assert>
         <assert role="error" test="matches(substring(., 34, 1), '[01cdefhijmpsu\|]')">
            <value-of select="concat($record001, ' :: ')"/>Literary form (char position 34, 1) must match '[01cdefhijmpsu\|]'.</assert>
         <assert role="error" test="matches(substring(., 35, 1), '[\p{Zs}abcd\|]')">
            <value-of select="concat($record001, ' :: ')"/>Biography (char position 35, 1) must match '[\p{Zs}abcd\|]'.</assert>
      </rule>
   </pattern>
   <pattern>
      <title>008 COMPUTER FILES</title>
      <rule context="*:controlfield[@tag = '008'][matches(substring(../*:leader, 7, 1), 'm')]">
         <let name="record001"
              value="ancestor::*:record/*:controlfield[@tag = '001']"/>
         <!-- Requirements -->
         <assert role="error" test="matches(substring(., 19, 4), '[\p{Zs}\|]{4}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 19, 4) must match '[\p{Zs}\|]{4}'.</assert>
         <assert role="error" test="matches(substring(., 23, 1), '[\p{Zs}abcdefgj\|]')">
            <value-of select="concat($record001, ' :: ')"/>Target audience (char position 23, 1) must match '[\p{Zs}abcdefgj\|]'.</assert>
         <assert role="error" test="matches(substring(., 24, 1), '[oq\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of item (char position 24, 1) must match '[oq\p{Zs}\|]'.</assert>
         <assert role="error" test="matches(substring(., 25, 2), '[\p{Zs}\|]{2}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 25, 2) must match '[\p{Zs}\|]{2}'.</assert>
         <assert role="error" test="matches(substring(., 27, 1), '[abcdefghijmuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Type of computer file (char position 27, 1) must match '[abcdefghijmuz\|]'.</assert>
         <assert role="error" test="matches(substring(., 28, 1), '[\p{Zs}\|]')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 28, 1) must match '[\p{Zs}\|]'.</assert>
         <assert role="error"
                 test="matches(substring(., 29, 1), '[\p{Zs}acfilmosuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Government publication (char position 29, 1) must match '[\p{Zs}acfilmosuz\|]'.</assert>
         <assert role="error" test="matches(substring(., 30, 6), '[\p{Zs}\|]{6}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 30, 6) must match '[\p{Zs}\|]{6}'.</assert>
      </rule>
