         <assert role="error" test="matches(substring(., 23, 1), '[\p{Zs}abcdefgj\|]')">
            <value-of select="concat($record001, ' :: ')"/>Target audience (char position 23, 1) must match '[\p{Zs}abcdefgj\|]'.</assert>
         <assert role="error" test="matches(substring(., 24, 5), '[\p{Zs}\|]{5}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 24, 5) must match '[\p{Zs}\|]{5}'.</assert>
         <assert role="error"
                 test="matches(substring(., 29, 1), '[\p{Zs}acfilmnosuz\|]')">
            <value-of select="concat($record001, ' :: ')"/>Government publication (char position 29, 1) must match '[\p{Zs}acfilmnosuz\|]'.</assert>
         <assert role="error" test="matches(substring(., 30, 1), '[\p{Zs}abcdfoqrs\|]')">
            <value-of select="concat($record001, ' :: ')"/>Form of item (char position 30, 1) must match '[\p{Zs}abcdfoqrs\|]'.</assert>
         <assert role="error" test="matches(substring(., 31, 3), '[\p{Zs}\|]{3}')">
            <value-of select="concat($record001, ' :: ')"/>Undefined (char position 31, 3) must match '[\p{Zs}\|]{3}'.</assert>
         <assert role="error"
