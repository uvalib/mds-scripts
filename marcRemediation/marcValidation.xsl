  <variable name="record001" select="ancestor::*:record/*:controlfield[@tag = '001']"/>
  <template match="*:record/*[matches(local-name(), 'controlfield|datafield')]"
    mode="group.d2e20" priority="640">
    <param name="Q{http://dmaus.name/ns/2023/schxslt}pattern"
      as="Q{http://www.w3.org/2001/XMLSchema}string*" select="()"/>
    <choose>
      <when test="'d2e20' = $Q{http://dmaus.name/ns/2023/schxslt}pattern">
        <svrl:suppressed-rule context="*:record/*[matches(local-name(),
          'controlfield|datafield')]">
          <if test="document-uri()">
            <attribute name="document" select="document-uri()"/>
          </if>
        </svrl:suppressed-rule>
        <next-match>
          <with-param name="Q{http://dmaus.name/ns/2023/schxslt}pattern"
            as="Q{http://www.w3.org/2001/XMLSchema}string*"
            select="$Q{http://dmaus.name/ns/2023/schxslt}pattern"/>
        </next-match>
      </when>
      <otherwise>
        <svrl:fired-rule context="*:record/*[matches(local-name(),
          'controlfield|datafield')]">
          <if test="document-uri()">
            <attribute name="document" select="document-uri()"/>
          </if>
        </svrl:fired-rule>
        <variable name="localName" select="local-name()"/>
        <variable name="record001"
          select="ancestor::*:record/*:controlfield[@tag = '001']"/>
        <if
          test="not(matches(@tag, '^((0([0-9A-Z][0-9A-Z])|0([1-9a-z][0-9a-z]))|(([1-9A-Z][0-9A-Z]{2})|([1-9a-z][0-9a-z]{2})))$'))">
          <variable name="failed-assert" as="element(svrl:failed-assert)">
            <svrl:failed-assert role="error" test="matches(@tag,
              '^((0([0-9A-Z][0-9A-Z])|0([1-9a-z][0-9a-z]))|(([1-9A-Z][0-9A-Z]{{2}})|([1-9a-z][0-9a-z]{{2}})))$')">
              <attribute name="location" select="path(.)"/>
              <svrl:text>
                <value-of select="concat($record001, ' :: ')"/>
                <value-of
                  select="concat('invalid ', lower-case($localName), ' ', @tag, '.')"/>
              </svrl:text>
            </svrl:failed-assert>
          </variable>
          <sequence select="$failed-assert"/>
        </if>
        <next-match>
          <with-param name="Q{http://dmaus.name/ns/2023/schxslt}pattern"
            as="Q{http://www.w3.org/2001/XMLSchema}string*"
            select="('d2e20', $Q{http://dmaus.name/ns/2023/schxslt}pattern)"/>
        </next-match>
      </otherwise>
    </choose>
  </template>
