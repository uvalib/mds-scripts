            <if test="$Q{http://www.w3.org/2005/xqt-errors}description">
              <value-of select="$Q{http://www.w3.org/2005/xqt-errors}description"/>
            </if>
          </svrl:error>
          <variable name="message" as="Q{http://www.w3.org/2001/XMLSchema}string+"
            expand-text="yes"> Running the ISO Schematron validation failed with a dynamic
            error. Error code: {$Q{http://www.w3.org/2005/xqt-errors}code} Reason:
            {$Q{http://www.w3.org/2005/xqt-errors}description} </variable>
          <message terminate="yes"
            error-code="Q{{http://dmaus.name/ns/2023/schxslt}}ValidationError">
            <text/>
            <value-of select="normalize-space(string-join($message))"/>
          </message>
        </catch>
      </try>
    </svrl:schematron-output>
  </template>
